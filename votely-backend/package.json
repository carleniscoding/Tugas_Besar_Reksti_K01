{
  "name": "votely-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test dist/shared/serializers.test.js",
    "prisma:generate": "prisma generate --schema ../votely-web/prisma/schema.prisma --config ../votely-web/prisma.config.js --generator backendClient",
    "prisma:migrate": "prisma migrate deploy --schema ../votely-web/prisma/schema.prisma --config ../votely-web/prisma.config.js",
    "prisma:migrate:dev": "prisma migrate dev --schema ../votely-web/prisma/schema.prisma --config ../votely-web/prisma.config.js"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "7.0.0",
    "@supabase/supabase-js": "^2.86.0",
    "@types/swagger-ui-express": "^4.1.8",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "ethers": "^6.15.0",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "pg": "^8.16.3",
    "swagger-ui-express": "^5.0.1",
    "thirdweb": "^5.114.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.19.0",
    "@types/pg": "^8.15.6",
    "prisma": "7.0.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
